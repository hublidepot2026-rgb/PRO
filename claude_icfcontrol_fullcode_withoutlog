/************************************
 * CONFIG  —  edit only this section
 ************************************/
const SHEET_NAME    = 'ICF_PRO_UBL_2026';
const CALENDAR_NAME = 'ICF_Due_Alerts';
const LOG_SHEET_URL = '';  // ← paste your Change Log Google Sheet URL here
const BATCH_SIZE    = 15;  // 15 coaches per batch — safe for rate limit

// Srl | Train No | Coach Number | Coach Type | POH Date | IOH Date | Return Date
//  0       1            2             3           4          5           6
const COL_TRAIN  = 1;
const COL_COACH  = 2;
const COL_TYPE   = 3;
const COL_POH    = 4;
const COL_IOH    = 5;
const COL_RETURN = 6;

const REMINDER_START_DAYS = 10;
const COL_HEADERS = ['Srl','Train No','Coach Number','Coach Type','POH Date','IOH Date','Return Date'];

