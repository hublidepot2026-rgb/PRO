/************************************
 * CONFIG  —  edit only this section
 ************************************/
const SHEET_NAME    = 'ICF_PRO_UBL_2026';
const CALENDAR_NAME = 'ICF_Due_Alerts';
const LOG_TAB_NAME  = 'Change_Log';
const BATCH_SIZE    = 15;

// Srl | Train No | Coach Number | Coach Type | POH Date | IOH Date | Return Date | Sync Status
//  0       1            2             3           4          5           6               7
const COL_TRAIN  = 1;
const COL_COACH  = 2;
const COL_TYPE   = 3;
const COL_POH    = 4;
const COL_IOH    = 5;
const COL_RETURN = 6;
const COL_STATUS = 7;

const REMINDER_START_DAYS = 10;
const COL_HEADERS = ['Srl','Train No','Coach Number','Coach Type','POH Date','IOH Date','Return Date','Sync Status'];

